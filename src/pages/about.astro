---
import MainLayout from "../layouts/MainLayout.astro";
import { aboutPage } from "../data/en/about";
import { site } from "../data/en/site";
import { pathWithBase } from "../lib/paths";
---

<MainLayout title="About | CHARM" description={site.description}>
  <section class="page-hero">
    <div class="page-hero-overlay">
      <div class="page-hero-copy shell">
        <h1>{aboutPage.title}</h1>
        <p>{aboutPage.intro}</p>
        <div class="page-hero-actions">
          <a class="button-primary" href={pathWithBase("/contact")}>{site.contactLabel}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="page-section about-intro-section">
    <div class="shell">
      <div class="about-summary-card">
        <p>{aboutPage.summary}</p>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="shell">
      <div class="about-card-grid">
        <article class="about-info-card">
          <h2>Business Focus</h2>
          <ul class="page-check-list">
            {aboutPage.focus.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="about-info-card">
          <h2>Values</h2>
          <ul class="page-check-list">
            {aboutPage.values.map((item) => <li>{item}</li>)}
          </ul>
        </article>

        <article class="about-info-card">
          <h2>Coverage and Language</h2>
          <ul class="page-check-list">
            {aboutPage.area.map((item) => <li>{item}</li>)}
            {aboutPage.language.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="page-section about-process-section">
    <div class="shell">
      <div class="page-section-heading page-section-heading-center">
        <h2>How It Works</h2>
        <p>A simple path for understanding the building, the shared spaces, and the next step.</p>
      </div>

      <div class="about-process-grid">
        {aboutPage.process.map((item, index) => (
          <article class="about-process-card">
            <span>{index + 1}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="page-section page-final-section">
    <div class="shell">
      <div class="page-section-heading page-section-heading-center">
        <h2>Frequently Asked Questions</h2>
      </div>

      <div class="page-faq-list">
        {aboutPage.faq.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</MainLayout>

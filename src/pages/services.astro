---
import MainLayout from "../layouts/MainLayout.astro";
import { servicesPage } from "../data/en/services";
import { site } from "../data/en/site";
import { pathWithBase } from "../lib/paths";
---

<MainLayout title="Services | CHARM" description="Common-area cleaning services for condo buildings in Saint-Laurent and nearby Montreal.">
  <section class="services-hero">
    <div class="services-hero-overlay">
      <div class="services-hero-copy shell">
        <h1>{servicesPage.title}</h1>
        <p>{servicesPage.intro}</p>
      </div>
    </div>
  </section>

  <section class="services-section services-reasons-section">
    <div class="shell">
      <div class="services-section-heading">
        <h2>Why choose our services?</h2>
        <p>{servicesPage.reasonsIntro}</p>
      </div>

      <ul class="services-reason-list">
        {servicesPage.reasons.map((item) => (
          <li>
            <div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="services-section services-details-section">
    <div class="shell">
      <div class="services-section-heading">
        <h2>Services offered in more detail</h2>
        <p>{servicesPage.serviceDetailsIntro}</p>
      </div>

      <div class="services-detail-stack">
        {servicesPage.serviceDetails.map((service) => (
          <article class="services-detail-row">
            <div class="services-image-placeholder" aria-label={service.placeholder}>
              <span>{service.placeholder}</span>
            </div>

            <div class="services-detail-copy">
              <h3>{service.title}</h3>
              <p>{service.summary}</p>
              <ul class="services-detail-points">
                {service.points.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="services-section">
    <div class="shell">
      <div class="services-scope-card">
        <div>
          <h2>Outside CHARM's cleaning scope</h2>
          <p>{servicesPage.notIncludedIntro}</p>
        </div>

        <ul class="services-scope-list">
          {servicesPage.notIncluded.map((item) => (
            <li>
              <span>{item.title}</span>
              <small>{item.description}</small>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="services-section">
    <div class="shell">
      <div class="services-section-heading services-section-heading-center">
        <h2>Services FAQ</h2>
      </div>

      <div class="home-faq-list services-faq-list">
        {servicesPage.faq.map((item) => (
          <details>
            <summary>
              <h3>{item.question}</h3>
            </summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="services-section services-final-section">
    <div class="shell">
      <div class="services-final-cta">
        <h2>{servicesPage.finalCta.title}</h2>
        <p>{servicesPage.finalCta.description}</p>
        <a class="button-primary" href={pathWithBase("/quote")}>{site.quoteLabel}</a>
      </div>
    </div>
  </section>
</MainLayout>

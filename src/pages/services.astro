---
import MainLayout from "../layouts/MainLayout.astro";
import { servicesPage } from "../data/en/services";
import { site } from "../data/en/site";
import { pathWithBase } from "../lib/paths";
---

<MainLayout title="Services | CHARM" description="Common-area cleaning services for condo buildings in Saint-Laurent and nearby Montreal.">
  <section class="services-section services-details-section">
    <div class="shell">
      <div class="services-intro-panel">
        <h1>{servicesPage.heroTitle}</h1>
        <p>{servicesPage.intro}</p>
      </div>

      <div class="services-detail-stack">
        {servicesPage.serviceDetails.map((service) => (
          <article class="services-detail-row">
            {service.image ? (
              <figure class="services-detail-image">
                <img
                  src={pathWithBase(service.image.src)}
                  alt={service.image.alt}
                  width={service.image.width}
                  height={service.image.height}
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            ) : (
              <div class="services-image-placeholder" aria-label={service.placeholder}>
                <span>{service.placeholder}</span>
              </div>
            )}

            <div class="services-detail-copy">
              <h3>{service.title}</h3>
              <p>{service.summary}</p>
              <ul class="services-detail-points">
                {service.points.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="services-section services-final-section">
    <div class="services-final-cta">
      <div class="services-final-cta-content">
        <h2>{servicesPage.finalCta.title}</h2>
        <p>{servicesPage.finalCta.description}</p>
        <a class="button-primary" href={pathWithBase("/contact")}>{site.contactLabel}</a>
      </div>
    </div>
  </section>

  <section class="services-section">
    <div class="shell">
      <div class="services-section-heading services-section-heading-center">
        <h2>Services Questions</h2>
      </div>

      <div class="home-faq-list services-faq-list">
        {servicesPage.faq.map((item) => (
          <details>
            <summary>
              <h3>{item.question}</h3>
            </summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</MainLayout>

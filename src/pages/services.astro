---
import MainLayout from "../layouts/MainLayout.astro";
import { servicesPage } from "../data/en/services";
import { site } from "../data/en/site";
import { pathWithBase } from "../lib/paths";

const iconLogo = pathWithBase("/brand/charm-logo-icon.png");
---

<MainLayout title="Services | CHARM" description="Common-area cleaning services for condo buildings in Saint-Laurent and nearby Montreal.">
  <section class="services-hero">
    <div class="services-hero-overlay">
      <div class="services-hero-copy shell">
        <img src={iconLogo} alt="" width="70" height="70" loading="eager" decoding="async" />
        <h1>{servicesPage.title}</h1>
        <p>{servicesPage.intro}</p>
        <div class="services-hero-actions">
          <a class="button-primary" href={pathWithBase("/quote")}>{site.quoteLabel}</a>
          <a class="button-secondary" href={pathWithBase("/contact")}>Ask a Question</a>
        </div>
      </div>
    </div>
  </section>

  <section class="services-section services-highlights-section">
    <div class="shell">
      <div class="services-highlight-grid">
        {servicesPage.highlights.map((item) => (
          <article class="services-highlight-card">
            <h2>{item.title}</h2>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="services-section">
    <div class="shell">
      <div class="services-section-heading">
        <h2>Common areas CHARM cleans</h2>
        <p>{servicesPage.servicesIntro}</p>
      </div>

      <div class="services-category-grid">
        {servicesPage.categories.map((category) => (
          <article class="services-category-card">
            <div>
              <h3>{category.title}</h3>
              <p>{category.summary}</p>
            </div>

            <ul class="services-clean-list">
              {category.items.map((item) => (
                <li>
                  <span>{item.title}</span>
                  <small>{item.description}</small>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="services-section services-planning-section">
    <div class="shell">
      <div class="services-section-heading services-section-heading-center">
        <h2>Service planning</h2>
        <p>{servicesPage.planningIntro}</p>
      </div>

      <div class="services-plan-grid">
        <article class="services-plan-card">
          <h3>Buildings we work with</h3>
          <div class="services-line-list">
            {servicesPage.buildingTypes.map((item) => (
              <div class="services-line-item">
                <h4>{item.title}</h4>
                <p>{item.description}</p>
              </div>
            ))}
          </div>
        </article>

        <article class="services-plan-card">
          <h3>Recurring service options</h3>
          <div class="services-line-list">
            {servicesPage.frequencies.map((item) => (
              <div class="services-line-item">
                <h4>{item.title}</h4>
                <p>{item.description}</p>
              </div>
            ))}
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="services-section">
    <div class="shell">
      <div class="services-scope-card">
        <div>
          <h2>Outside CHARM's cleaning scope</h2>
          <p>{servicesPage.notIncludedIntro}</p>
        </div>

        <ul class="services-scope-list">
          {servicesPage.notIncluded.map((item) => (
            <li>
              <span>{item.title}</span>
              <small>{item.description}</small>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="services-section services-final-section">
    <div class="shell">
      <div class="services-final-cta">
        <h2>Need cleaning for a condo building?</h2>
        <p>Send the building type, shared spaces, and cleaning frequency you have in mind. CHARM can follow up with the next step.</p>
        <a class="button-primary" href={pathWithBase("/quote")}>{site.quoteLabel}</a>
      </div>
    </div>
  </section>
</MainLayout>

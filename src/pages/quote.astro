---
import MainLayout from "../layouts/MainLayout.astro";
import QuoteRequestForm from "../components/forms/QuoteRequestForm.astro";
import { quotePage } from "../data/en/quote";
import { site } from "../data/en/site";
---

<MainLayout title="Request a Quote | CHARM" description={site.description}>
  <section class="page-hero page-hero-compact">
    <div class="page-hero-overlay">
      <div class="page-hero-copy shell">
        <h1>{quotePage.title}</h1>
        <p>{quotePage.intro}</p>
      </div>
    </div>
  </section>

  <section class="page-section page-final-section">
    <div class="shell">
      <div class="form-page-grid">
        <aside class="form-intro-card">
          <p class="form-kicker">Quote request</p>
          <h2>Use Quote for building details.</h2>
          <p>{quotePage.note}</p>

          <ul class="page-check-list">
            {quotePage.quoteFit.map((item) => <li>{item}</li>)}
          </ul>
        </aside>

        <div class="form-card">
          <QuoteRequestForm />
        </div>
      </div>
    </div>
  </section>
</MainLayout>

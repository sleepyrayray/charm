---
import MainLayout from "../layouts/MainLayout.astro";
import QuoteRequestForm from "../components/forms/QuoteRequestForm.astro";
import { quotePage } from "../data/en/quote";
import { site } from "../data/en/site";
---

<MainLayout title="Request a Quote | CHARM" description={site.description}>
  <section class="shell pb-20 pt-10 sm:pb-24 sm:pt-14">
    <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
      <div class="panel section-card">
        <h1 class="section-title">{quotePage.title}</h1>
        <p class="section-copy mt-4">{quotePage.intro}</p>
        <div class="mt-8 rounded-lg border border-dashed border-[var(--line)] bg-white/70 p-5 text-sm leading-7 text-[var(--muted)]">
          {quotePage.note}
        </div>
      </div>

      <div class="panel section-card">
        <QuoteRequestForm />
      </div>
    </div>
  </section>
</MainLayout>

---
import MainLayout from "../layouts/MainLayout.astro";
import { contactPage } from "../data/en/contact";
import { site } from "../data/en/site";
---

<MainLayout title="Contact | CHARM" description={site.description}>
  <section class="shell pt-10 sm:pt-14">
    <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
      <div class="panel section-card">
        <h1 class="section-title">{contactPage.title}</h1>
        <p class="section-copy mt-4">{contactPage.intro}</p>
        <div class="mt-8 rounded-lg border border-dashed border-[var(--line)] bg-white/70 p-5 text-sm leading-7 text-[var(--muted)]">
          {contactPage.note}
        </div>
        <div class="mt-6">
          <a class="button-primary" href="/quote">{site.quoteLabel}</a>
        </div>
      </div>

      <div class="panel section-card">
        <form class="grid gap-4" aria-describedby="contact-form-note">
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="grid gap-2 text-sm font-medium">
              <span>Name</span>
              <input class="field" type="text" name="name" placeholder="Your name" />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              <span>Phone</span>
              <input class="field" type="tel" name="phone" placeholder="Phone number" />
            </label>
          </div>

          <label class="grid gap-2 text-sm font-medium">
            <span>Email</span>
            <input class="field" type="email" name="email" placeholder="Email address" />
          </label>

          <label class="grid gap-2 text-sm font-medium">
            <span>Message</span>
            <textarea class="field min-h-36" name="message" placeholder="Ask a question or leave a short message."></textarea>
          </label>

          <p id="contact-form-note" class="text-sm leading-7 text-[var(--muted)]">
            This inquiry form is for general messages. Use the quote page for building details and service requests.
          </p>

          <div class="pt-2">
            <button class="button-primary opacity-70" type="button">Contact flow coming next</button>
          </div>
        </form>
      </div>
    </div>
  </section>
</MainLayout>

---
import MainLayout from "../layouts/MainLayout.astro";
import { home } from "../data/en/home";
import { site } from "../data/en/site";
---

<MainLayout title="CHARM | Cleaning Services" description={site.description}>
  <section class="shell pt-12 sm:pt-16">
    <div class="grid gap-10 lg:min-h-[560px] lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div class="max-w-3xl space-y-6">
        <h1 class="text-4xl font-semibold sm:text-5xl lg:text-6xl">{home.title}</h1>
        <p class="section-copy">{home.intro}</p>
        <div class="flex flex-wrap gap-3">
          <a class="button-primary" href="/quote">{site.quoteLabel}</a>
          <a class="button-secondary" href="/services">View Services</a>
        </div>
      </div>

      <div class="hero-panel">
        <div>
          <h2 class="text-xl font-semibold text-[var(--ink)]">Built for condo common areas</h2>
          <p class="mt-3 text-sm leading-7 text-[var(--muted)]">
            Recurring cleaning for the shared spaces residents and managers see every day.
          </p>
        </div>
        <ul class="detail-list mt-6">
          {home.heroNotes.map((note) => (
            <li>{note}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section-band mt-6">
    <div class="shell">
      <h2 class="section-title">Shared spaces, kept presentable.</h2>
      <p class="section-copy mt-4">
        The everyday areas that need steady care, from entrances to shared amenities.
      </p>

      <div class="info-grid mt-8">
        {home.serviceAreas.map((area) => (
          <article class="info-card">
            <h3>{area.title}</h3>
            <p>{area.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="shell mt-16">
    <h2 class="section-title">For the people responsible for the building.</h2>
    <p class="section-copy mt-4">
      CHARM is meant for condo decision-makers who want common areas to stay clean, presentable, and cared for.
    </p>

    <div class="info-grid mt-8">
      {home.audiences.map((audience) => (
        <article class="info-card">
          <h3>{audience.title}</h3>
          <p>{audience.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-band mt-16">
    <div class="shell">
      <div class="max-w-2xl">
        <h2 class="section-title">Why choose CHARM?</h2>
      </div>

      <div class="mt-8 grid gap-4 lg:grid-cols-3">
        {home.reasons.map((reason) => (
          <article class="quiet-card">
            <h3 class="text-lg font-semibold text-[var(--ink)]">{reason.title}</h3>
            <p class="mt-3 text-sm leading-7 text-[var(--muted)]">{reason.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="shell mt-16 pb-10">
    <div class="cta-strip">
      <div>
        <h2 class="section-title">{home.finalCtaTitle}</h2>
        <p class="section-copy mt-3">{home.finalCtaBody}</p>
      </div>
      <a class="button-primary" href="/quote">{site.quoteLabel}</a>
    </div>
  </section>
</MainLayout>

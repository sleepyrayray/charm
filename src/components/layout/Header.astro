---
import { navigation as enNavigation, site as enSite } from "../../data/en/site";
import { navigation as frNavigation, site as frSite } from "../../data/fr/site";
import { pathWithBase, pathWithoutBase } from "../../lib/paths";

interface Props {
  locale?: "en" | "fr";
  currentPath: string;
}

const { locale = "en", currentPath } = Astro.props;
const site = locale === "fr" ? frSite : enSite;
const navigation = locale === "fr" ? frNavigation : enNavigation;
const routePath = pathWithoutBase(currentPath);
const quoteHref = pathWithBase(locale === "fr" ? "/fr/quote" : "/quote");
const homeHref = pathWithBase(locale === "fr" ? "/fr" : "/");
const primaryLogo = pathWithBase("/brand/charm-logo-primary.png");
const iconLogo = pathWithBase("/brand/charm-logo-icon.png");
const brandLabel = `${site.brand} ${site.subtext}`;

const switchHref = locale === "fr"
  ? pathWithBase(routePath.replace(/^\/fr/, "") || "/")
  : pathWithBase(`/fr${routePath === "/" ? "" : routePath}`);
---

<header class="sticky top-0 z-40">
  <div class="site-header-panel">
    <div class="shell">
      <div class="flex items-center justify-between py-3">
        <a href={homeHref} class="brand-link" aria-label={brandLabel}>
          <img class="brand-logo brand-logo-primary" src={primaryLogo} alt="" width="188" height="61" decoding="async" />
          <img class="brand-logo-icon" src={iconLogo} alt="" width="48" height="48" decoding="async" />
          <span class="sr-only">{brandLabel}</span>
        </a>

        <nav class="hidden items-center gap-2 md:flex">
          {navigation.map((item) => {
            const active = routePath === item.href;

            return (
              <a
                href={pathWithBase(item.href)}
                aria-current={active ? "page" : undefined}
                class:list={[
                  "rounded-lg px-4 py-2 text-sm font-medium transition",
                  active ? "bg-[var(--primary-soft)] text-[var(--primary-strong)]" : "text-[var(--ink)] hover:bg-white",
                ]}
              >
                {item.label}
              </a>
            );
          })}
        </nav>

        <div class="hidden items-center gap-3 md:flex">
          <a href={quoteHref} class="button-primary">{site.quoteLabel}</a>
          <a href={switchHref} class="rounded-lg border border-[var(--line)] px-3 py-2 text-xs font-semibold text-[var(--muted)]">{site.languageLabel}</a>
        </div>

        <div class="flex items-center gap-2 md:hidden">
          <a href={switchHref} class="rounded-lg border border-[var(--line)] px-3 py-2 text-xs font-semibold text-[var(--muted)]">{site.languageLabel}</a>
          <a href={quoteHref} class="button-primary px-4">{site.quoteLabel}</a>
        </div>
      </div>

      <nav class="flex flex-wrap gap-2 pb-3 md:hidden">
        {navigation.map((item) => {
          const active = routePath === item.href;

          return (
            <a
              href={pathWithBase(item.href)}
              aria-current={active ? "page" : undefined}
              class:list={[
                "rounded-lg px-4 py-2 text-sm font-medium transition",
                active
                  ? "bg-[var(--primary-soft)] text-[var(--primary-strong)]"
                  : "panel text-[var(--ink)]",
              ]}
            >
              {item.label}
            </a>
          );
        })}
      </nav>
    </div>
  </div>
</header>

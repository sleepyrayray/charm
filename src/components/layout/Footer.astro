---
import { navigation as enNavigation, site as enSite } from "../../data/en/site";
import { navigation as frNavigation, site as frSite } from "../../data/fr/site";

interface Props {
  locale?: "en" | "fr";
}

const { locale = "en" } = Astro.props;
const site = locale === "fr" ? frSite : enSite;
const navigation = locale === "fr" ? frNavigation : enNavigation;
const summary = locale === "fr"
  ? "Entretien menager des aires communes pour immeubles en copropriete."
  : "Recurring common-area cleaning for condo buildings in Saint-Laurent and nearby Montreal.";
---

<footer class="mt-20 pb-10">
  <div class="shell">
    <div class="panel rounded-lg px-6 py-8 sm:px-8">
      <div class="grid gap-8 md:grid-cols-[1.4fr_1fr]">
        <div>
          <div class="text-sm font-semibold text-[var(--primary-strong)]">{site.brand}</div>
          <div class="mt-1 text-sm text-[var(--muted)]">{site.subtext}</div>
          <p class="mt-4 max-w-xl text-sm leading-7 text-[var(--muted)]">{summary}</p>
        </div>

        <div class="grid gap-2 text-sm text-[var(--muted)]">
          {navigation.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
          <div class="pt-3 text-xs uppercase text-[var(--primary-strong)]">
            CHARM SERVICE DE NETTOYAGE s.e.n.c.
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

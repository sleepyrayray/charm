---
import { navigation as enNavigation, site as enSite } from "../../data/en/site";
import { navigation as frNavigation, site as frSite } from "../../data/fr/site";
import { pathWithBase } from "../../lib/paths";

interface Props {
  locale?: "en" | "fr";
}

const { locale = "en" } = Astro.props;
const site = locale === "fr" ? frSite : enSite;
const navigation = locale === "fr" ? frNavigation : enNavigation;
const homeHref = pathWithBase(locale === "fr" ? "/fr" : "/");
const primaryLogo = pathWithBase("/brand/charm-logo-primary.png");
const brandLabel = `${site.brand} ${site.subtext}`;
const summary = locale === "fr"
  ? "Entretien menager des aires communes pour immeubles en copropriete."
  : "Recurring common-area cleaning for condo buildings in Saint-Laurent and nearby Montreal.";
---

<footer class="site-footer">
  <div class="site-footer-panel">
    <div class="shell py-8 sm:py-10">
      <div class="grid gap-8 md:grid-cols-[1.4fr_1fr]">
        <div>
          <a href={homeHref} class="footer-brand-card" aria-label={brandLabel}>
            <img class="footer-brand-logo" src={primaryLogo} alt="" width="210" height="68" loading="lazy" decoding="async" />
            <span class="sr-only">{brandLabel}</span>
          </a>
          <p class="mt-5 max-w-xl text-sm leading-7 text-white/80">{summary}</p>
        </div>

        <div class="grid justify-items-start gap-2 text-sm text-white/80">
          {navigation.map((item) => (
            <a class="w-fit transition hover:text-white" href={pathWithBase(item.href)}>{item.label}</a>
          ))}
          <div class="pt-3 text-xs uppercase text-white/70">
            CHARM SERVICE DE NETTOYAGE s.e.n.c.
          </div>
          <div class="text-xs uppercase text-white/70">
            &copy; CREATED BY{" "}
            <a class="text-white underline-offset-4 transition hover:underline" href="https://sleepyrayray.github.io/my-portfolio/">
              RAY HERNAEZ
            </a>
            . ALL RIGHTS RESERVED.
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

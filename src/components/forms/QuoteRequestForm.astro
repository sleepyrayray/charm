---
interface Props {
  noteId?: string;
  note?: string;
  buttonLabel?: string;
}

const {
  noteId = "quote-form-note",
  note = "This will become the dedicated quote request flow once form delivery is connected.",
  buttonLabel = "Quote flow coming next",
} = Astro.props;
---

<form class="quote-form grid gap-4" aria-describedby={noteId}>
  <div class="grid gap-4 sm:grid-cols-2">
    <label class="grid gap-2 text-sm font-medium">
      <span>Name</span>
      <input class="field" type="text" name="name" placeholder="Your name" />
    </label>
    <label class="grid gap-2 text-sm font-medium">
      <span>Phone</span>
      <input class="field" type="tel" name="phone" placeholder="Phone number" />
    </label>
  </div>

  <label class="grid gap-2 text-sm font-medium">
    <span>Email</span>
    <input class="field" type="email" name="email" placeholder="Email address" />
  </label>

  <div class="grid gap-4 sm:grid-cols-2">
    <label class="grid gap-2 text-sm font-medium">
      <span>Building or organisation</span>
      <input class="field" type="text" name="building" placeholder="Building or organisation" />
    </label>
    <label class="grid gap-2 text-sm font-medium">
      <span>Property address or area</span>
      <input class="field" type="text" name="area" placeholder="Saint-Laurent, Montreal, etc." />
    </label>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <label class="grid gap-2 text-sm font-medium">
      <span>Building type</span>
      <input class="field" type="text" name="buildingType" placeholder="Condo building, multi-unit, etc." />
    </label>
    <label class="grid gap-2 text-sm font-medium">
      <span>Cleaning frequency needed</span>
      <input class="field" type="text" name="frequency" placeholder="Daily, weekly, custom" />
    </label>
  </div>

  <label class="grid gap-2 text-sm font-medium">
    <span>Areas to clean</span>
    <input class="field" type="text" name="areas" placeholder="Lobby, hallways, stairwells, gym, etc." />
  </label>

  <div class="grid gap-4 sm:grid-cols-2">
    <label class="grid gap-2 text-sm font-medium">
      <span>Preferred language</span>
      <select class="field" name="language">
        <option>English</option>
        <option>French</option>
      </select>
    </label>
    <label class="grid gap-2 text-sm font-medium">
      <span>Preferred contact method</span>
      <select class="field" name="contactMethod">
        <option>Email</option>
        <option>Phone</option>
      </select>
    </label>
  </div>

  <label class="grid gap-2 text-sm font-medium">
    <span>Message</span>
    <textarea class="field min-h-36" name="message" placeholder="Tell CHARM a little about the property and cleaning needs."></textarea>
  </label>

  <p id={noteId} class="text-sm leading-7 text-[var(--muted)]">
    {note}
  </p>

  <div class="flex justify-center pt-2">
    <button class="button-primary opacity-70" type="button">{buttonLabel}</button>
  </div>
</form>

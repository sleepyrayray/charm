---
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import { pathWithBase } from "../lib/paths";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  locale?: "en" | "fr";
}

const { title, description, locale = "en" } = Astro.props;
const currentPath = Astro.url.pathname;
const brandIcon = pathWithBase("/brand/charm-logo-icon.png");
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#007887" />
    <link rel="icon" type="image/png" href={brandIcon} />
    <link rel="apple-touch-icon" href={brandIcon} />
  </head>
  <body>
    <Header locale={locale} currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
